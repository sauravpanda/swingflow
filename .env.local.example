# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# wcs-api (Railway service URL). Local dev: http://localhost:8080
NEXT_PUBLIC_WCS_API_URL=http://localhost:8080

# Stripe publishable key (Phase 2 — leave blank for Phase 1)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PostHog analytics (optional — analytics no-ops if blank)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Datafast page-view tracker (optional). Both vars must be set to
# enable — otherwise the <Script> tag is not rendered.
# Get your site ID at https://datafa.st/
NEXT_PUBLIC_DATAFAST_SITE_ID=
NEXT_PUBLIC_DATAFAST_DOMAIN=
