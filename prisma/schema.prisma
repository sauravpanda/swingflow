generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Read-only reference data (served via API) ---

model Pattern {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  beats          Int      @default(6)
  difficulty     String   // beginner, intermediate, advanced
  category       String   // basics, push-pull, turns, whips, wraps, slides
  description    String
  mechanics      String   // JSON string: step-by-step mechanics
  commonMistakes String   // JSON string: common mistakes
  videoUrl       String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  checklistTemplates ChecklistTemplate[]
}

model AnchorType {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  description String
  execution   String // JSON string: execution steps
  musicality  String // when to use this anchor
  difficulty  String // beginner, intermediate, advanced
  imageUrl    String?
}

model ChecklistTemplate {
  id        String @id @default(cuid())
  patternId String
  category  String // connection, frame, posture, timing, styling
  item      String
  sortOrder Int    @default(0)

  pattern Pattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
}
