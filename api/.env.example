# ─────────────────────────────────────────────────────────────
# Supabase — Project Settings → API
# ─────────────────────────────────────────────────────────────
# Your Supabase project URL (e.g. https://abcd1234.supabase.co).
SUPABASE_URL=https://xxxxx.supabase.co
# Optional. Only used when the project serves HS256 tokens (legacy).
# Leave empty for asymmetric-key (JWKS) projects — the default.
SUPABASE_JWT_SECRET=
# Settings → API → service_role (secret). Needed for quota enforcement,
# Stripe webhook writes, and analysis persistence. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# CORS — comma-separated list of origins allowed to call this API.
# Add your production origin (e.g. https://yourdomain.com) here.
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Music analysis limits (server-side enforced)
# ─────────────────────────────────────────────────────────────
MAX_MUSIC_BYTES=26214400        # 25 MB
MAX_MUSIC_SECONDS=480           # 8 minutes

# ─────────────────────────────────────────────────────────────
# Video analysis — Gemini
# ─────────────────────────────────────────────────────────────
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default in code is gemini-3.1-pro-preview (requires Google AI paid
# billing). Override to gemini-2.5-flash for free-tier scoring; quality
# drops noticeably but it still works.
GEMINI_MODEL=gemini-3.1-pro-preview
# Max accepted upload size. 500 MB covers 5+ minute phone clips.
MAX_VIDEO_BYTES=524288000       # 500 MB
# Plan quotas — match these to your business model.
FREE_MONTHLY_VIDEO=2
FREE_MAX_VIDEO_SECONDS=120      # 2 min
BASIC_MONTHLY_VIDEO=10
BASIC_MAX_VIDEO_SECONDS=300     # 5 min

# ─────────────────────────────────────────────────────────────
# Cloudflare R2 (S3-compatible object storage for video uploads)
# ─────────────────────────────────────────────────────────────
# Dashboard → R2 → Manage R2 API Tokens → Account ID (the hex that
# prefixes <id>.r2.cloudflarestorage.com).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=swingflow-uploads
# Seconds the browser's presigned PUT URL stays valid (1h default).
R2_UPLOAD_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────────────
# Stripe — optional, only needed for paid-tier billing
# ─────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys → Secret key
STRIPE_SECRET_KEY=
# Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# The price ID for your Basic plan (price_...)
STRIPE_PRICE_ID=
