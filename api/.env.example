# Supabase — copy these from your Supabase project dashboard.
# Settings → API → Project URL
SUPABASE_URL=https://xxxxx.supabase.co
# Settings → API → JWT Secret (used to verify user access tokens)
SUPABASE_JWT_SECRET=
# Settings → API → service_role (secret) — needed by Stripe webhook in Phase 2
SUPABASE_SERVICE_ROLE_KEY=

# CORS — comma-separated list of origins allowed to call this API.
# Add your Cloudflare Pages production origin here before going live.
ALLOWED_ORIGINS=http://localhost:3000

# Music analysis limits
MAX_MUSIC_BYTES=26214400
MAX_MUSIC_SECONDS=480

# Video analysis (Phase 3)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
MAX_VIDEO_BYTES=104857600
FREE_MONTHLY_VIDEO=1
FREE_MAX_VIDEO_SECONDS=120
BASIC_MONTHLY_VIDEO=10
BASIC_MAX_VIDEO_SECONDS=300
